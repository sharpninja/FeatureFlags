# SharpNinja Feature Flags - environment variable reference
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# --------------------------------------------------------------------------
# ngrok tunneling (required when running: docker compose up ngrok)
# Get your authtoken at: https://dashboard.ngrok.com/get-started/your-authtoken
# --------------------------------------------------------------------------
NGROK_AUTHTOKEN=

# --------------------------------------------------------------------------
# Database passwords
# Defaults below are for local development only.
# Change these for staging/production deployments.
# --------------------------------------------------------------------------
FEATUREFLAGS_POSTGRES_PASSWORD=featureflags_dev_password
FEATUREFLAGS_SQLSERVER_PASSWORD=SharpNinja!Passw0rd

# --------------------------------------------------------------------------
# Distribution service API keys
# SDK instances present these in the X-SharpNinja-Api-Key request header.
# --------------------------------------------------------------------------
FEATUREFLAGS_TRUCKMATE_DISTRIBUTION_KEY=truckmate_distribution_dev_key
FEATUREFLAGS_DRIVERMATE_DISTRIBUTION_KEY=drivermate_distribution_dev_key

# --------------------------------------------------------------------------
# Device attestation test tokens (Distribution service)
# SDK instances present these in the X-SharpNinja-Device-Attestation header.
# --------------------------------------------------------------------------
FEATUREFLAGS_TRUCKMATE_ATTESTATION_TOKEN=truckmate_attestation_dev_token
FEATUREFLAGS_DRIVERMATE_ATTESTATION_TOKEN=drivermate_attestation_dev_token
