{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Distribution": {
    "Authorization": {
      "RequireDeviceAttestation": false
    },
    "Storage": {
      "Mode": "FileSystem",
      "RootPath": "App_Data/distribution"
    },
    "Cdn": {
      "EnableCacheHeaders": true,
      "ManifestMaxAgeSeconds": 15,
      "ManifestStaleWhileRevalidateSeconds": 60,
      "ManifestStaleIfErrorSeconds": 300
    },
    "ApiKeys": {
      "truckmate": [
        "truckmate-dev-key"
      ],
      "drivermate": [
        "drivermate-dev-key"
      ]
    },
    "DeviceAttestation": {
      "TestTokens": {
        "*": [
          "local-test-attestation"
        ]
      }
    }
  }
}
