@using Microsoft.AspNetCore.Components.Web
@code {
    private static readonly IComponentRenderMode InteractiveServer = new InteractiveServerRenderMode(prerender: false);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>SharpNinja FeatureFlags Admin</title>
    <HeadOutlet @rendermode="@InteractiveServer" />
</head>
<body>
    <Routes @rendermode="@InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
